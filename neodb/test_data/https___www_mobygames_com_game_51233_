bd\u03c4\u03b1\u03c3\u03c4\u03b9\u03ba\u03ae \u03b1\u03c6\u03ae\u03b3\u03b7\u03c3\u03b7. \u039c\u03cc\u03bd\u03bf \u03c0\u03b1\u03c1\u03ac\u03c0\u03bf\u03bd\u03bf \u03c0\u03bf\u03c5 \u03bc\u03c0\u03bf\u03c1\u03b5\u03af \u03bd\u03b1 \u03b5\u03ba\u03c6\u03c1\u03ac\u03c3\u03b5\u03b9 \u03ba\u03ac\u03c0\u03bf\u03b9\u03bf\u03c2 \u03b5\u03af\u03bd\u03b1\u03b9 \u03cc\u03c4\u03b9 \u03c4\u03bf Portal \u03b4\u03b5\u03bd \u03c7\u03c1\u03b5\u03b9\u03b1\u03b6\u03cc\u03c4\u03b1\u03bd \u03c0\u03c1\u03b1\u03b3\u03bc\u03b1\u03c4\u03b9\u03ba\u03ac sequel, \u03c4\u03cc\u03c3\u03bf \u03b1\u03c5\u03c4\u03cc\u03bd\u03bf\u03bc\u03b7 \u03ba\u03b1\u03b9 \u03c0\u03bb\u03ae\u03c1\u03b7\u03c2 \u03b5\u03bc\u03c0\u03b5\u03b9\u03c1\u03af\u03b1 \u03ae\u03c4\u03b1\u03bd. \u0391\u03c0\u03cc \u03c4\u03b7\u03bd \u03c3\u03c4\u03b9\u03b3\u03bc\u03ae \u03c0\u03bf\u03c5 \u03c4\u03bf \u03b1\u03c0\u03ad\u03ba\u03c4\u03b7\u03c3\u03b5, \u03cc\u03bc\u03c9\u03c2, \u03c4\u03bf sequel \u03cc\u03c6\u03b5\u03b9\u03bb\u03b5 \u03bd\u03b1 \u03b5\u03af\u03bd\u03b1\u03b9 \u03c0\u03b9\u03c3\u03c4\u03cc \u03c3\u03c4\u03bf \u03c0\u03bd\u03b5\u03cd\u03bc\u03b1 \u03c4\u03bf\u03c5 original, \u03b1\u03bb\u03bb\u03ac \u03b5\u03c0\u03b5\u03ba\u03c4\u03b5\u03af\u03bd\u03bf\u03bd\u03c4\u03b1\u03c2 \u03c4\u03b7\u03bd \u03c0\u03c1\u03cc\u03ba\u03bb\u03b7\u03c3\u03ae \u03c4\u03bf\u03c5 \u03ba\u03b1\u03b9 \u03c4\u03b7\u03bd \u03b9\u03c3\u03c4\u03bf\u03c1\u03af\u03b1 \u03c4\u03bf\u03c5.", "date": "2011-04-19", "edit_object_url": "/approval/edit-object?type=47\u0026oid=45669131", "grade": null, "id": 218861, "internal_url": "https://www.mobygames.com/game/51233/portal-2/reviews/#critic-score-218861", "language": "el", "max_score": 10.0, "normalized_score": 90.0, "platform": {"id": 69, "name": "Xbox 360"}, "score": 9.0, "source": {"country": {"country_code": "gr", "flag": "https://cdn.mobygames.com/c4c520ca-ab5e-11ed-b6d6-02420a000150.gif", "id": 10, "name": "Greece"}, "description": null, "edit_object_url": "/approval/edit-object?type=46\u0026oid=49257935", "first_year": 2008, "id": 1045, "internal_url": "https://www.mobygames.com/critic/1045/gameover-greece/", "languages": [{"code": "el", "id": 48, "name": "Greek", "ordering": 480}], "last_year": null, "name": "GameOver (Greece)", "num_reviews": 347, "url": "https://www.gameover.gr/"}, "submitter": {"id": 163111, "internal_url": "https://www.mobygames.com/user/163111/cavalary/", "name": "Cavalary"}, "type": {"id": 1, "name": "Numeric (Highest score is best)"}, "url": "http://www.gameover.gr/x360/reviews/Portal-2.15655.html"}, {"citation": "Valve will continue to make Portal titles because they are fantastic. Portal 2 offers unique gameplay not experienced in any other game; it is funny, exhilarating and challenging.", "date": "2011-04-20", "edit_object_url": "/approval/edit-object?type=47\u0026oid=45505357", "grade": null, "id": 218755, "internal_url": "https://www.mobygames.com/game/51233/portal-2/reviews/#critic-score-218755", "language": "en", "max_score": 10.0, "normalized_score": 90.0, "platform": {"id": 3, "name": "Windows"}, "score": 9.0, "source": {"country": {"country_code": "us", "flag": "https://cdn.mobygames.com/9f436050-ab5e-11ed-b6d6-02420a000150.gif", "id": 1, "name": "United States"}, "description": null, "edit_object_url": "/approval/edit-object?type=46\u0026oid=49257817", "first_year": 2008, "id": 1087, "internal_url": "https://www.mobygames.com/critic/1087/gamers-daily-news/", "languages": [{"code": "en", "id": 36, "name": "English", "ordering": 360}], "last_year": null, "name": "Gamers Daily News", "num_reviews": 104, "url": "http://www.gamersdailynews.com/index.php"}, "submitter": {"id": 163111, "internal_url": "https://www.mobygames.com/user/163111/cavalary/", "name": "Cavalary"}, "type": {"id": 1, "name": "Numeric (Highest score is best)"}, "url": "http://www.gamersdailynews.com/article-2854-Portal-2-Review-Video-PC-Steam-Version.html"}, {"citation": "Una sceneggiatura raffinata e dei giochi di logica che solleticheranno la nostra mente e ci terranno incollati allo schermo: ecco quello che Portal in definitiva \u00e8. Un titolo artisticamente raffinato e ricco di scorci surreali, che premier\u00e0 la notra intelligenza e capacit\u00e0 di adattamento ad un universo paradossale e intrigante. Consiglio a tutti questo Puzzle Game unico nel suo genere, che vi terr\u00e0 impegnati, a seconda della vostra abilit\u00e0 col \u201cpensiero laterale\u201d, dalle 8-10 ore per la campagna in singolo e ad altre 6-8 ore per la campagna cooperativa. Perdersi in questo mondo governato dalle macchine e dalla Scienza sfrenata \u00e8 un\u2019esperienza da provare. Come dicevo in principio, una perla rara, un titolo fuori dagli schemi in un periodo in cui troppo spesso l\u2019obiettivo di una Software House \u00e8 puntare al blockbuster e al profitto ad ogni costo, rinunciando all\u2019originalit\u00e0 e all\u2019azzardo.", "date": "2011-04-25", "edit_object_url": "/approval/edit-object?type=47\u0026oid=45992999", "grade": null, "id": 261731, "internal_url": "https://www.mobygames.com/game/51233/portal-2/reviews/#critic-score-261731", "language": "it", "max_score": 10.0, "normalized_score": 90.0, "platform": {"id": 69, "name": "Xbox 360"}, "score": 9.0, "source": {"country": {"country_code": "it", "flag": "https://cdn.mobygames.com/9f5b5804-ab5e-11ed-b6d6-02420a000150.gif", "id": 12, "name": "Italy"}, "description": null, "edit_object_url": "/approval/edit-object?type=46\u0026oid=49258027", "first_year": 2007, "id": 837, "internal_url": "https://www.mobygames.com/critic/837/gamescollection/", "languages": [{"code": "it", "id": 64, "name": "Italian", "ordering": 640}], "last_year": null, "name": "GamesCollection", "num_reviews": 613, "url": "http://www.gamescollection.it/"}, "submitter": {"id": 183114, "internal_url": "https://www.mobygames.com/user/183114/alsy/", "name": "Alsy"}, "type": {"id": 1, "name": "Numeric (Highest score is best)"}, "url": "http://www.gamescollection.it/reviews/show/560"}, {"citation": "Portal 2 is available on three platforms (Xbox 360, PlayStation 3, and PC), but all three versions feature the same content. The advantage with the PC version is that it includes, as a separate download, an editor that lets you create and share new levels with other Portal 2 owners, increasing its longevity. The PlayStation 3 version also includes a code to download the PC version of Portal 2 at no extra cost, so if you want the best of both worlds, the PS3 version is the way to go. No matter which version you choose, however, you\u0027ll want to take it slow and savor the game. You may not be advancing science, but playing Portal 2 is nonetheless an enriching experience.", "date": "2011", "edit_object_url": "/approval/edit-object?type=47\u0026oid=45625890", "grade": null, "id": 214431, "internal_url": "https://www.mobygames.com/game/51233/portal-2/reviews/#critic-score-214431", "language": "en", "max_score": 5.0, "normalized_score": 90.0, "platform": {"id": 74, "name": "Macintosh"}, "score": 4.5, "source": {"country": {"country_code": "us", "flag": "https://cdn.mobygames.com/9f436050-ab5e-11ed-b6d6-02420a000150.gif", "id": 1, "name": "United States"}, "description": null, "edit_object_url": "/approval/edit-object?type=46\u0026oid=49259437", "first_year": 1992, "id": 290, "internal_url": "https://www.mobygames.com/critic/290/all-game-guide/", "languages": [{"code": "en", "id": 36, "name": "English", "ordering": 360}], "last_year": 2014, "name": "All Game Guide", "num_reviews": 3345, "url": "http://www.allgame.com/"}, "submitter": {"id": 55856, "internal_url": "https://www.mobygames.com/user/55856/scaryfun/", "name": "Scaryfun"}, "type": {"id": 2, "name": "Star System"}, "url": "http://www.allgame.com/game.php?id=71973\u0026tab=review"}, {"citation": "Portal 2 on loistava taidonn\u00e4yte Valvelta. Peli ei aliarvioi pelaajia ja t\u00e4ytt\u00e4\u00e4 fanien odotukset 100-prosenttisen varmasti. Pikkuasioista voi valittaa, mutta en ep\u00e4ile v\u00e4itt\u00e4\u00e4, ett\u00e4 kyseess\u00e4 on yksi vuoden parhaimpia pelej\u00e4. Peli tarjoaa makeaa mahan t\u00e4ydelt\u00e4 ja j\u00e4tt\u00e4\u00e4 silti toivomaan entist\u00e4 enemm\u00e4n lis\u00e4\u00e4. Onneksi peli, saavutuksineen ja salaisuuksineen, tarjoaa uudelleenpelattavuutta ruhtinaallisesti.", "date": "2011-04-19", "edit_object_url": "/approval/edit-object?type=47\u0026oid=45667691", "grade": null, "id": 218795, "internal_url": "https://www.mobygames.com/game/51233/portal-2/reviews/#critic-score-218795", "language": "fi", "max_score": 10.0, "normalized_score": 90.0, "platform": {"id": 74, "name": "Macintosh"}, "score": 9.0, "source": {"country": {"country_code": "fi", "flag": "https://cdn.mobygames.com/9f553136-ab5e-11ed-b6d6-02420a000150.gif", "id": 7, "name": "Finland"}, "description": null, "edit_object_url": "/approval/edit-object?type=46\u0026oid=49257962", "first_year": 2007, "id": 918, "internal_url": "https://www.mobygames.com/critic/918/gamereactor-finland/", "languages": [{"code": "fi", "id": 41, "name": "Finnish", "ordering": 410}], "last_year": null, "name": "Gamereactor (Finland)", "num_reviews": 204, "url": "http://www.gamereactor.fi/"}, "submitter": {"id": 163111, "internal_url": "https://www.mobygames.com/user/163111/cavalary/", "name": "Cavalary"}, "type": {"id": 1, "name": "Numeric (Highest score is best)"}, "url": "http://www.gamereactor.fi/arviot/80399/"}, {"citation": "Valve\u0027s Gabe Newell has said that Portal 2 is the best game Valve has ever done. That\u0027s a pretty tricky statement to judge, because almost every game the company makes has been amazing. In the same way it doesn\u0027t really mean anything if I were to say it is one of their best games ever. Instead, let me just say this: Portal 2 managed to surpass my very high expectations of it and it\u0027s the perfect sequel to the classic Portal. It does everything right and doesn\u0027t take a single wrong step. It\u0027s a game that everyone should play and I can\u0027t recommend it enough.", "date": "2011-04-19", "edit_object_url": "/approval/edit-object?type=47\u0026oid=45667692", "grade": null, "id": 218796, "internal_url": "https://www.mobygames.com/game/51233/portal-2/reviews/#critic-score-218796", "language": "en", "max_score": 10.0, "normalized_score": 90.0, "platform": {"id": 74, "name": "Macintosh"}, "score": 9.0, "source": {"country": {"country_code": "dk", "flag": "https://cdn.mobygames.com/c4d8fa64-ab5e-11ed-b6d6-02420a000150.gif", "id": 26, "name": "Denmark"}, "description": null, "edit_object_url": "/approval/edit-object?type=46\u0026oid=49257890", "first_year": 2009, "id": 1413, "internal_url": "https://www.mobygames.com/critic/1413/gamereactor-international/", "languages": [{"code": "en", "id": 36, "name": "English", "ordering": 360}], "last_year": null, "name": "Gamereactor International", "num_reviews": 619, "url": "http://www.gamereactor.eu/"}, "submitter": {"id": 163111, "internal_url": "https://www.mobygames.com/user/163111/cavalary/", "name": "Cavalary"}, "type": {"id": 1, "name": "Numeric (Highest score is best)"}, "url": "http://www.gamereactor.eu/reviews/7153/"}, {"citation": "Portal 2 delivers, and it does it in style, creating one of the most meticulously designed, thrilling and delightful playgrounds we\u2019ve ever seen. It\u2019s a game with a magical take on momentum, where single bounds over tall buildings are business as usual, where every surface is a potential launchpad, and the entire experience is a belly laugh. Valve has a pretty good record with the number two, but attempting to inflate Portal\u2019s perfectly formed package could easily have been a disaster. Naturally, the sequel doesn\u2019t feel as bracingly fresh as the 2007 game, but it\u2019s precisely the sort of dizzying follow-up the original deserves.", "date": "2011-04-19", "edit_object_url": "/approval/edit-object?type=47\u0026oid=45669303", "grade": null, "id": 218970, "internal_url": "https://www.mobygames.com/game/51233/portal-2/reviews/#critic-score-218970", "language": "en", "max_score": 10.0, "normalized_score": 90.0, "platform": {"id": 74, "name": "Macintosh"}, "score": 9.0, "source": {"country": {"country_code": "uk", "flag": "https://cdn.mobygames.com/9f7e9f08-ab5e-11ed-b6d6-02420a000150.gif", "id": 22, "name": "United Kingdom"}, "description": null, "edit_object_url": "/approval/edit-object?type=46\u0026oid=49252876", "first_year": 1993, "id": 129, "internal_url": "https://www.mobygames.com/critic/129/edge/", "languages": [{"code": "en", "id": 36, "name": "English", "ordering": 360}], "last_year": null, "name": "Edge", "num_reviews": 1477, "url": "http://www.edge-online.com/"}, "submitter": {"id": 163111, "internal_url": "https://www.mobygames.com/user/163111/cavalary/", "name": "Cavalary"}, "type": {"id": 1, "name": "Numeric (Highest score is best)"}, "url": "http://www.next-gen.biz/reviews/portal-2-review"}, {"citation": "Portal 2 ist ein nahezu perfektes Spiel f\u00fcr das, was es ist. Es gibt Kleinigkeiten wie nun v\u00f6llig unbewegliches Interior, was sich anfangs komisch anf\u00fchlt, weil alles auf mysteri\u00f6se Art und Weise am Boden klebt. Vielleicht haben sie bei Valve in Tests herausgefunden, dass einige Spieler sich einfach zu lange damit besch\u00e4ftigt haben, das Zeug durch die Level zu schleppen auf der Suche nach der L\u00f6sung... wer wei\u00df. Richtig schade ist nur, dass die Kampagne - je nach nach F\u00e4higkeiten - in sieben bis zehn Stunden erledigt ist. Dazu gesellen sich vier bis sechs Stunden Koop-Material. Das ist eigentlich genug, aber man will einfach nicht, dass es endet. Und hatte mir GLaDOS nicht am Anfang versprochen, dass ich hier f\u00fcr immer testen darf? Verdammte L\u00fcgnerin! Anderseits: Das war sie doch schon immer, oder etwa nicht!?!", "date": "2011-04-19", "edit_object_url": "/approval/edit-object?type=47\u0026oid=45672301", "grade": null, "id": 218797, "internal_url": "https://www.mobygames.com/game/51233/portal-2/reviews/#critic-score-218797", "language": "de", "max_score": 10.0, "normalized_score": 90.0, "platform": {"id": 74, "name": "Macintosh"}, "score": 9.0, "source": {"country": {"country_code": "dk", "flag": "https://cdn.mobygames.com/c4d8fa64-ab5e-11ed-b6d6-02420a000150.gif", "id": 26, "name": "Denmark"}, "description": null, "edit_object_url": "/approval/edit-object?type=46\u0026oid=49257965", "first_year": 2009, "id": 1559, "internal_url": "https://www.mobygames.com/critic/1559/gamereactor-germany/", "languages": [{"code": "de", "id": 47, "name": "German", "ordering": 470}], "last_year": null, "name": "Gamereactor (Germany)", "num_reviews": 51, "url": "http://www.gamereactor.de/"}, "submitter": {"id": 163111, "internal_url": "https://www.mobygames.com/user/163111/cavalary/", "name": "Cavalary"}, "type": {"id": 1, "name": "Numeric (Highest score is best)"}, "url": "http://www.gamereactor.de/Kritiken/5850/"}, {"citation": "Portal 2 ist ein nahezu perfektes Spiel f\u00fcr das, was es ist. Es gibt Kleinigkeiten wie nun v\u00f6llig unbewegliches Interior, was sich anfangs komisch anf\u00fchlt, weil alles auf mysteri\u00f6se Art und Weise am Boden klebt. Vielleicht haben sie bei Valve in Tests herausgefunden, dass einige Spieler sich einfach zu lange damit besch\u00e4ftigt haben, das Zeug durch die Level zu schleppen auf der Suche nach der L\u00f6sung... wer wei\u00df. Richtig schade ist nur, dass die Kampagne - je nach nach F\u00e4higkeiten - in sieben bis zehn Stunden erledigt ist. Dazu gesellen sich vier bis sechs Stunden Koop-Material. Das ist eigentlich genug, aber man will einfach nicht, dass es endet. Und hatte mir GLaDOS nicht am Anfang versprochen, dass ich hier f\u00fcr immer testen darf? Verdammte L\u00fcgnerin! Anderseits: Das war sie doch schon immer, oder etwa nicht!?!", "date": "2011-04-19", "edit_object_url": "/approval/edit-object?type=47\u0026oid=45667697", "grade": null, "id": 218800, "internal_url": "https://www.mobygames.com/game/51233/portal-2/reviews/#critic-score-218800", "language": "de", "max_score": 10.0, "normalized_score": 90.0, "platform": {"id": 69, "name": "Xbox 360"}, "score": 9.0, "source": {"country": {"country_code": "dk", "flag": "https://cdn.mobygames.com/c4d8fa64-ab5e-11ed-b6d6-02420a000150.gif", "id": 26, "name": "Denmark"}, "description": null, "edit_object_url": "/approval/edit-object?type=46\u0026oid=49257965", "first_year": 2009, "id": 1559, "internal_url": "https://www.mobygames.com/critic/1559/gamereactor-germany/", "languages": [{"code": "de", "id": 47, "name": "German", "ordering": 470}], "last_year": null, "name": "Gamereactor (Germany)", "num_reviews": 51, "url": "http://www.gamereactor.de/"}, "submitter": {"id": 163111, "internal_url": "https://www.mobygames.com/user/163111/cavalary/", "name": "Cavalary"}, "type": {"id": 1, "name": "Numeric (Highest score is best)"}, "url": "http://www.gamereactor.de/Kritiken/5850/"}, {"citation": "Portal 2 on loistava taidonn\u00e4yte Valvelta. Peli ei aliarvioi pelaajia ja t\u00e4ytt\u00e4\u00e4 fanien odotukset 100-prosenttisen varmasti. Pikkuasioista voi valittaa, mutta en ep\u00e4ile v\u00e4itt\u00e4\u00e4, ett\u00e4 kyseess\u00e4 on yksi vuoden parhaimpia pelej\u00e4. Peli tarjoaa makeaa mahan t\u00e4ydelt\u00e4 ja j\u00e4tt\u00e4\u00e4 silti toivomaan entist\u00e4 enemm\u00e4n lis\u00e4\u00e4. Onneksi peli, saavutuksineen ja salaisuuksineen, tarjoaa uudelleenpelattavuutta ruhtinaallisesti.", "date": "2011-04-19", "edit_object_url": "/approval/edit-object?type=47\u0026oid=45667687", "grade": null, "id": 218793, "internal_url": "https://www.mobygames.com/game/51233/portal-2/reviews/#critic-score-218793", "language": "fi", "max_score": 10.0, "normalized_score": 90.0, "platform": {"id": 69, "name": "Xbox 360"}, "score": 9.0, "source": {"country": {"country_code": "fi", "flag": "https://cdn.mobygames.com/9f553136-ab5e-11ed-b6d6-02420a000150.gif", "id": 7, "name": "Finland"}, "description": null, "edit_object_url": "/approval/edit-object?type=46\u0026oid=49257962", "first_year": 2007, "id": 918, "internal_url": "https://www.mobygames.com/critic/918/gamereactor-finland/", "languages": [{"code": "fi", "id": 41, "name": "Finnish", "ordering": 410}], "last_year": null, "name": "Gamereactor (Finland)", "num_reviews": 204, "url": "http://www.gamereactor.fi/"}, "submitter": {"id": 163111, "internal_url": "https://www.mobygames.com/user/163111/cavalary/", "name": "Cavalary"}, "type": {"id": 1, "name": "Numeric (Highest score is best)"}, "url": "http://www.gamereactor.fi/arviot/80399/"}, {"citation": "Very few gaming moments can compare to completing a particularly difficult Portal 2 puzzle. Whether you\u2019ve played the original or not, the dialogue will have you laughing, the unsolved puzzles will leave you pulling your hair out, and the completed ones beaming like mad.", "date": "2011-04-18", "edit_object_url": "/approval/edit-object?type=47\u0026oid=45755182", "grade": null, "id": 231915, "internal_url": "https://www.mobygames.com/game/51233/portal-2/reviews/#critic-score-231915", "language": "en", "max_score": 5.0, "normalized_score": 90.0, "platform": {"id": 74, "name": "Macintosh"}, "score": 4.5, "source": {"country": {"country_code": "us", "flag": "https://cdn.mobygames.com/9f436050-ab5e-11ed-b6d6-02420a000150.gif", "id": 1, "name": "United States"}, "description": null, "edit_object_url": "/approval/edit-object?type=46\u0026oid=49257909", "first_year": 2006, "id": 688, "internal_url": "https://www.mobygames.com/critic/688/maclife/", "languages": [{"code": "en", "id": 36, "name": "English", "ordering": 360}], "last_year": null, "name": "MacLife", "num_reviews": 192, "url": "http://www.maclife.com/"}, "submitter": {"id": 183114, "internal_url": "https://www.mobygames.com/user/183114/alsy/", "name": "Alsy"}, "type": {"id": 2, "name": "Star System"}, "url": "http://www.maclife.com/article/reviews/portal_2_review"}, {"citation": "Portal 2 k\u00e4nns av naturliga sk\u00e4l inte nyskapande p\u00e5 det s\u00e4tt som f\u00f6reg\u00e5ngaren gjorde, men \u00e4nd\u00e5 \u00e4r formeln oerh\u00f6rt fr\u00e4sch och det kan onekligen vara sk\u00f6nt att f\u00e5 ta sig igenom ett spel utan att beh\u00f6va d\u00f6da ett or\u00e4kneligt antal fiender. Portal 2 \u00e4r en av spel\u00e5rets h\u00f6jdpunkter, och f\u00f6rtj\u00e4nar att spelas av alla.", "date": "2011-04-21", "edit_object_url": "/approval/edit-object?type=47\u0026oid=45667686", "grade": null, "id": 218791, "internal_url": "https://www.mobygames.com/game/51233/portal-2/reviews/#critic-score-218791", "language": "sv", "max_score": 10.0, "normalized_score": 90.0, "platform": {"id": 69, "name": "Xbox 360"}, "score": 9.0, "source": {"country": {"country_code": "se", "flag": "https://cdn.mobygames.com/9f3d1a06-ab5e-11ed-b6d6-02420a000150.gif", "id": 21, "name": "Sweden"}, "description": null, "edit_object_url": "/approval/edit-object?type=46\u0026oid=49257649", "first_year": 2010, "id": 1495, "internal_url": "https://www.mobygames.com/critic/1495/eurogamerse/", "languages": [{"code": "sv", "id": 137, "name": "Swedish", "ordering": 1370}], "last_year": null, "name": "Eurogamer.se", "num_reviews": 100, "url": "http://www.eurogamer.se/"}, "submitter": {"id": 163111, "internal_url": "https://www.mobygames.com/user/163111/cavalary/", "name": "Cavalary"}, "type": {"id": 1, "name": "Numeric (Highest score is best)"}, "url": "http://www.eurogamer.se/articles/2011-04-21-portal-2-recension"}, {"citation": "Portal 2 er et spill som skiller seg fra mengden. Det gir en tilfredsstillende f\u00f8lelse \u00e5 l\u00f8se de intrikate g\u00e5tene, som takket v\u00e6re str\u00e5lende brettdesign holder seg utfordrende og interessante gjennom hele spillet. Valve leverer dialog og humor i s\u00e6rklasse, og for meg var det helt umulig \u00e5 ikke la seg bli sjarmert s\u00f8nder og sammen av robotenes personlighet. Sleng p\u00e5 en str\u00e5lende samarbeidsdel p\u00e5 toppen av det hele, og Portal 2 lever opp til forventningene. Hvem liker vel ikke roboter med f\u00f8lelser?", "date": "2011-04-19", "edit_object_url": "/approval/edit-object?type=47\u0026oid=45616415", "grade": null, "id": 210111, "internal_url": "https://www.mobygames.com/game/51233/portal-2/reviews/#critic-score-210111", "language": "no", "max_score": 10.0, "normalized_score": 90.0, "platform": {"id": 81, "name": "PlayStation 3"}, "score": 9.0, "source": {"country": {"country_code": "no", "flag": "https://cdn.mobygames.com/d7733c3e-ab5e-11ed-b6d6-02420a000150.gif", "id": 34, "name": "Norway"}, "description": null, "edit_object_url": "/approval/edit-object?type=46\u0026oid=49257793", "first_year": 2000, "id": 1310, "internal_url": "https://www.mobygames.com/critic/1310/gamereactor-norway/", "languages": [{"code": "no", "id": 102, "name": "Norwegian", "ordering": 1020}], "last_year": null, "name": "Gamereactor (Norway)", "num_reviews": 168, "url": "http://www.gamereactor.no/"}, "submitter": {"id": 55154, "internal_url": "https://www.mobygames.com/user/55154/disco-sounds-2088/", "name": "lights out party"}, "type": {"id": 1, "name": "Numeric (Highest score is best)"}, "url": "http://www.gamereactor.no/anmeldelser/124260/Portal+2/"}, {"citation": "Valves topchef Gabe Newell har sagt, at Portal 2 sandsynligvis er det bedste spil Valve nogensinde har lavet. Det er et udsagn der er sv\u00e6rt at bed\u00f8mme, fordi n\u00e6sten hvert eneste af udviklerens spil har v\u00e6ret skels\u00e6ttende. Af samme grund giver det heller ikke rigtig mening at kalde det for et af deres bedste spil. I stedet vil jeg sige dette: Portal 2 har overg\u00e5et mine temmelig h\u00f8je forventninger, og er den perfekte efterf\u00f8lger til det klassiske Portal. Det g\u00f8r alting rigtigt, og s\u00e6tter ikke en eneste fod forkert undervejs. Det er et spil alle burde pr\u00f8ve, og f\u00e5r min varmeste anbefaling.", "date": "2011-04-19", "edit_object_url": "/approval/edit-object?type=47\u0026oid=45616439", "grade": null, "id": 210108, "internal_url": "https://www.mobygames.com/game/51233/portal-2/reviews/#critic-score-210108", "language": "da", "max_score": 10.0, "normalized_score": 90.0, "platform": {"id": 81, "name": "PlayStation 3"}, "score": 9.0, "source": {"country": {"country_code": "dk", "flag": "https://cdn.mobygames.com/c4d8fa64-ab5e-11ed-b6d6-02420a000150.gif", "id": 26, "name": "Denmark"}, "description": null, "edit_object_url": "/approval/edit-object?type=46\u0026oid=49257795", "first_year": 1998, "id": 845, "internal_url": "https://www.mobygames.com/critic/845/gamereactor-denmark/", "languages": [{"code": "da", "id": 33, "name": "Danish", "ordering": 330}], "last_year": null, "name": "Gamereactor (Denmark)", "num_reviews": 775, "url": "https://www.gamereactor.dk/"}, "submitter": {"id": 55154, "internal_url": "https://www.mobygames.com/user/55154/disco-sounds-2088/", "name": "lights out party"}, "type": {"id": 1, "name": "Numeric (Highest score is best)"}, "url": "http://www.gamereactor.dk/anmeldelser/83540/Portal+2/"}, {"citation": "As you journey through the massive Aperture facility, it becomes clear that Portal 2 does not merely come after Portal. Instead, it radiates outward from its predecessor, simultaneously illuminating the world that gave rise to Portal and continuing the adventure that began there. The sense of novelty is diminished, but the thrill of exploration and puzzle-solving is still intoxicating, and it\u0027s amazing how Portal 2 manages to tell a better story with disembodied voices and spherical robots than most games can with full-on humans. Your return to Aperture Science is a joyful one in this immensely appealing, laugh-out-loud funny, and thoroughly satisfying sequel.", "date": "2011-04-19", "edit_object_url": "/approval/edit-object?type=47\u0026oid=45638881", "grade": null, "id": 215625, "internal_url": "https://www.mobygames.com/game/51233/portal-2/reviews/#critic-score-215625", "language": "en", "max_score": 10.0, "normalized_score": 90.0, "platform": {"id": 81, "name": "PlayStation 3"}, "score": 9.0, "source": {"country": {"country_code": "us", "flag": "https://cdn.mobygames.com/9f436050-ab5e-11ed-b6d6-02420a000150.gif", "id": 1, "name": "United States"}, "description": null, "edit_object_url": "/approval/edit-object?type=46\u0026oid=49258112", "first_year": 1995, "id": 1, "internal_url": "https://www.mobygames.com/critic/1/gamespot/", "languages": [{"code": "en", "id": 36, "name": "English", "ordering": 360}], "last_year": null, "name": "GameSpot", "num_reviews": 11888, "url": "http://www.gamespot.com/"}, "submitter": {"id": 184929, "internal_url": "https://www.mobygames.com/user/184929/crankystorming/", "name": "CrankyStorming"}, "type": {"id": 1, "name": "Numeric (Highest score is best)"}, "url": "http://uk.gamespot.com/ps3/action/portal-2/review.html"}, {"citation": "At a time when so many games just look and feel more and more the same to me, Portal 2 is unique and wonderful. Clearly it\u2019s going to be one of the best sequels in gaming this year, and it won\u2019t surprise me to see people saying it\u2019s the one they liked best.", "date": "2011-04-19", "edit_object_url": "/approval/edit-object?type=47\u0026oid=45667637", "grade": null, "id": 218757, "internal_url": "https://www.mobygames.com/game/51233/portal-2/reviews/#critic-score-218757", "language": "en", "max_score": 10.0, "normalized_score": 90.0, "platform": {"id": 69, "name": "Xbox 360"}, "score": 9.0, "source": {"country": {"country_code": "uk", "flag": "https://cdn.mobygames.com/9f7e9f08-ab5e-11ed-b6d6-02420a000150.gif", "id": 22, "name": "United Kingdom"}, "description": null, "edit_object_url": "/approval/edit-object?type=46\u0026oid=49259507", "first_year": 2003, "id": 440, "internal_url": "https://www.mobygames.com/critic/440/video-games-daily/", "languages": [{"code": "en", "id": 36, "name": "English", "ordering": 360}], "last_year": null, "name": "Video Games Daily", "num_reviews": 225, "url": "http://videogamesdaily.com/"}, "submitter": {"id": 163111, "internal_url": "https://www.mobygames.com/user/163111/cavalary/", "name": "Cavalary"}, "type": {"id": 1, "name": "Numeric (Highest score is best)"}, "url": "http://videogamesdaily.com/reviews/201104/review-is-portal-2-the-best-sequel-of-2011/"}, {"citation": "What you have then is a package brimming with quality. The singleplayer campaign expands on the original and turns it into a fully-fledged game. The co-operative mode is an entirely separate beast, with different chambers and puzzles, and can be accessed via split-screen or online. And then, as a final treat, you can revisit Portal 2 and listen to the developers comment on this game\u2019s creation. Were life to imitate art, we might all be shooting portals and stepping out through the other end. Indeed, this is both mathematical and storytelling art-work; it teams a gripping narrative with an inventive gameplay mechanic that makes for an excellent and unforgettable ride.", "date": "2011-05-21", "edit_object_url": "/approval/edit-object?type=47\u0026oid=45667596", "grade": null, "id": 218744, "internal_url": "https://www.mobygames.com/game/51233/portal-2/reviews/#critic-score-218744", "language": "en", "max_score": 10.0, "normalized_score": 90.0, "platform": {"id": 69, "name": "Xbox 360"}, "score": 9.0, "source": {"country": {"country_code": "us", "flag": "https://cdn.mobygames.com/9f436050-ab5e-11ed-b6d6-02420a000150.gif", "id": 1, "name": "United States"}, "description": null, "edit_object_url": "/approval/edit-object?type=46\u0026oid=49257887", "first_year": 2002, "id": 85, "internal_url": "https://www.mobygames.com/critic/85/thunderbolt-games/", "languages": [{"code": "en", "id": 36, "name": "English", "ordering": 360}], "last_year": null, "name": "Thunderbolt Games", "num_reviews": 1741, "url": "http://www.thunderboltgames.com/"}, "submitter": {"id": 163111, "internal_url": "https://www.mobygames.com/user/163111/cavalary/", "name": "Cavalary"}, "type": {"id": 1, "name": "Numeric (Highest score is best)"}, "url": "http://www.thunderboltgames.com/reviews/article/portal-2-review-for-xbox-360.html"}, {"citation": "Portal 2 manages to live up to the hype and be everything we loved about the first Portal, but with more. More tests, more toys and especially more of the great campaign\u2019s story and humour. Valve has done a bang-up job that\u2019s worth your money, but even more so if you are able to take advantage of the new co-op mode.", "date": "2011-05-24", "edit_object_url": "/approval/edit-object?type=47\u0026oid=45667580", "grade": null, "id": 218747, "internal_url": "https://www.mobygames.com/game/51233/portal-2/reviews/#critic-score-218747", "language": "en", "max_score": 10.0, "normalized_score": 90.0, "platform": {"id": 69, "name": "Xbox 360"}, "score": 9.0, "source": {"country": {"country_code": "za", "flag": "https://cdn.mobygames.com/847aab5c-1292-11ee-a162-02420a000154.png", "id": 46, "name": "South Africa"}, "description": null, "edit_object_url": "/approval/edit-object?type=46\u0026oid=49257957", "first_year": 2009, "id": 1453, "internal_url": "https://www.mobygames.com/critic/1453/lazygamer/", "languages": [{"code": "en", "id": 36, "name": "English", "ordering": 360}], "last_year": null, "name": "Lazygamer", "num_reviews": 57, "url": "http://www.lazygamer.net/"}, "submitter": {"id": 163111, "internal_url": "https://www.mobygames.com/user/163111/cavalary/", "name": "Cavalary"}, "type": {"id": 1, "name": "Numeric (Highest score is best)"}, "url": "http://www.lazygamer.net/xbox-360/portal-2-review-glad-you-could-make-it/"}, {"citation": "Portal 2 er utfordrende, og balanserer h\u00e5rfint mellom \u00e5 gi deg inntrykk av \u00e5 v\u00e6re djevelsk glup og fryktelig teit om hverandre. Vet du l\u00f8sningen p\u00e5 en g\u00e5te s\u00e5 er den for det meste overkommelig \u00e5 utf\u00f8re, og begrensningene ligger mellom \u00f8rene heller enn hvor treffsikker eller kjapp du er med styrestikka. Dette spillet skaper neppe like mye oppstyr som forgjengeren, men er noen gode hakk bedre. Inkluderingen av en fungerende historie er bare en av mange ting som gj\u00f8r at alle burde pr\u00f8ve en av \u00e5rets virkelige storspill.", "date": "2011-04-19", "edit_object_url": "/approval/edit-object?type=47\u0026oid=45665995", "grade": null, "id": 218741, "internal_url": "https://www.mobygames.com/game/51233/portal-2/reviews/#critic-score-218741", "language": "no", "max_score": 10.0, "normalized_score": 90.0, "platform": {"id": 69, "name": "Xbox 360"}, "score": 9.0, "source": {"country": {"country_code": "no", "flag": "https://cdn.mobygames.com/d7733c3e-ab5e-11ed-b6d6-02420a000150.gif", "id": 34, "name": "Norway"}, "description": null, "edit_object_url": "/approval/edit-object?type=46\u0026oid=49259472", "first_year": 2006, "id": 1132, "internal_url": "https://www.mobygames.com/critic/1132/gamerno/", "languages": [{"code": "no", "id": 102, "name": "Norwegian", "ordering": 1020}], "last_year": null, "name": "Gamer.no", "num_reviews": 629, "url": "http://www.gamer.no/"}, "submitter": {"id": 163111, "internal_url": "https://www.mobygames.com/user/163111/cavalary/", "name": "Cavalary"}, "type": {"id": 1, "name": "Numeric (Highest score is best)"}, "url": "http://www.gamer.no/artikler/82540/anmeldelse-portal-2/"}, {"citation": "Portal 2 er utfordrende, og balanserer h\u00e5rfint mellom \u00e5 gi deg inntrykk av \u00e5 v\u00e6re djevelsk glup og fryktelig teit om hverandre. Vet du l\u00f8sningen p\u00e5 en g\u00e5te s\u00e5 er den for det meste overkommelig \u00e5 utf\u00f8re, og begrensningene ligger mellom \u00f8rene heller enn hvor treffsikker eller kjapp du er med styrestikka. Dette spillet skaper neppe like mye oppstyr som forgjengeren, men er noen gode hakk bedre. Inkluderingen av en fungerende historie er bare en av mange ting som gj\u00f8r at alle burde pr\u00f8ve en av \u00e5rets virkelige storspill.", "date": "2011-04-19", "edit_object_url": "/approval/edit-object?type=47\u0026oid=45666017", "grade": null, "id": 218742, "internal_url": "https://www.mobygames.com/game/51233/portal-2/reviews/#critic-score-218742", "language": "no", "max_score": 10.0, "normalized_score": 90.0, "platform": {"id": 81, "name": "PlayStation 3"}, "score": 9.0, "source": {"country": {"country_code": "no", "flag": "https://cdn.mobygames.com/d7733c3e-ab5e-11ed-b6d6-02420a000150.gif", "id": 34, "name": "Norway"}, "description": null, "edit_object_url": "/approval/edit-object?type=46\u0026oid=49259472", "first_year": 2006, "id": 1132, "internal_url": "https://www.mobygames.com/critic/1132/gamerno/", "languages": [{"code": "no", "id": 102, "name": "Norwegian", "ordering": 1020}], "last_year": null, "name": "Gamer.no", "num_reviews": 629, "url": "http://www.gamer.no/"}, "submitter": {"id": 163111, "internal_url": "https://www.mobygames.com/user/163111/cavalary/", "name": "Cavalary"}, "type": {"id": 1, "name": "Numeric (Highest score is best)"}, "url": "http://www.gamer.no/artikler/82540/anmeldelse-portal-2/"}, {"citation": "Portal 2 is een geweldige puzzelgame die dankzij ingenieuze puzzels en een bijzonder humoristische verhaallijn jou als speler uren aan je scherm houdt. En met minstens de helft van die tijd met een grote glimlach op je gezicht.", "date": "2011-04-27", "edit_object_url": "/approval/edit-object?type=47\u0026oid=45666019", "grade": null, "id": 218745, "internal_url": "https://www.mobygames.com/game/51233/portal-2/reviews/#critic-score-218745", "language": "nl", "max_score": 10.0, "normalized_score": 90.0, "platform": {"id": 81, "name": "PlayStation 3"}, "score": 9.0, "source": {"country": {"country_code": "nl", "flag": "https://cdn.mobygames.com/c4f2d308-ab5e-11ed-b6d6-02420a000150.gif", "id": 16, "name": "The Netherlands"}, "description": null, "edit_object_url": "/approval/edit-object?type=46\u0026oid=49254211", "first_year": 2004, "id": 90, "internal_url": "https://www.mobygames.com/critic/90/gamernl/", "languages": [{"code": "nl", "id": 34, "name": "Dutch", "ordering": 340}], "last_year": null, "name": "Gamer.nl", "num_reviews": 913, "url": "http://www.gamers.nl/"}, "submitter": {"id": 163111, "internal_url": "https://www.mobygames.com/user/163111/cavalary/", "name": "Cavalary"}, "type": {"id": 1, "name": "Numeric (Highest score is best)"}, "url": "http://www.gamer.nl/review/67871/"}, {"citation": "There\u0027s just one other game like Portal 2 and that\u0027s the first Portal. Just like its predecessor, this sequel manages to wring every last ounce of enjoyment out of seemingly simple core concepts. If you\u0027re strictly into action its slow, plodding, calculated pace will be a turnoff. Yet, somehow Valve has managed to make a puzzle game that will make your pulse rise with a never ending daisy chain of positive reinforcement. It\u0027s bigger, more polished, and feels like a full-fledged game instead of an experiment, and we highly recommend it to any player ready to leave their comfort zone and feel smart in the process.", "date": "2011-04-19", "edit_object_url": "/approval/edit-object?type=47\u0026oid=45665991", "grade": null, "id": 218740, "internal_url": "https://www.mobygames.com/game/51233/portal-2/reviews/#critic-score-218740", "language": "en", "max_score": 10.0, "normalized_score": 90.0, "platform": {"id": 69, "name": "Xbox 360"}, "score": 9.0, "source": {"country": {"country_code": "us", "flag": "https://cdn.mobygames.com/9f436050-ab5e-11ed-b6d6-02420a000150.gif", "id": 1, "name": "United States"}, "description": null, "edit_object_url": "/approval/edit-object?type=46\u0026oid=49259458", "first_year": 2003, "id": 336, "internal_url": "https://www.mobygames.com/critic/336/gametrailers/", "languages": [{"code": "en", "id": 36, "name": "English", "ordering": 360}], "last_year": null, "name": "GameTrailers", "num_reviews": 767, "url": "http://www.gametrailers.com/"}, "submitter": {"id": 163111, "internal_url": "https://www.mobygames.com/user/163111/cavalary/", "name": "Cavalary"}, "type": {"id": 1, "name": "Numeric (Highest score is best)"}, "url": "http://www.gametrailers.com/gamereview.php?id=12821"}, {"citation": "Non, Portal 2 n\u2019est pas sup\u00e9rieur au premier \u00e9pisode. Il ne lui est pas non plus inf\u00e9rieur. Et c\u2019est peut-\u00eatre l\u00e0 le g\u00e9nie de Valve. Proposer une v\u00e9ritable suite, qui pourtant sait se d\u00e9tacher de son pr\u00e9d\u00e9cesseur. Pour imager cette id\u00e9e, disons que Portal 2 est \u00e0 Portal ce que Aliens et \u00e0 Alien. Bien que partant sur les m\u00eames bases, les deux jeux se r\u00e9v\u00e8lent radicalement diff\u00e9rents, notamment en termes de narration. Et, mine de rien, cela change tout. L\u2019exp\u00e9rience ressentie en jouant \u00e0 Portal 2 n\u2019est en rien comparable \u00e0 celle que nous avons tous v\u00e9cu en parcourant Portal. Et jouer \u00e0 une suite qui ne donne pas l\u2019impression d\u2019\u00eatre un simple copi\u00e9-coll\u00e9 de son pr\u00e9d\u00e9cesseur, cela fait beaucoup de bien.", "date": "2011-05-23", "edit_object_url": "/approval/edit-object?type=47\u0026oid=45643585", "grade": null, "id": 216133, "internal_url": "https://www.mobygames.com/game/51233/portal-2/reviews/#critic-score-216133", "language": "fr", "max_score": 20.0, "normalized_score": 90.0, "platform": {"id": 69, "name": "Xbox 360"}, "score": 18.0, "source": {"country": {"country_code": "fr", "flag": "https://cdn.mobygames.com/9f4ebb9e-ab5e-11ed-b6d6-02420a000150.gif", "id": 8, "name": "France"}, "description": null, "edit_object_url": "/approval/edit-object?type=46\u0026oid=49259430", "first_year": 2002, "id": 1549, "internal_url": "https://www.mobygames.com/critic/1549/xbox-mag/", "languages": [{"code": "fr", "id": 42, "name": "French", "ordering": 420}], "last_year": null, "name": "Xbox Mag", "num_reviews": 15, "url": "http://xbox-mag.net/"}, "submitter": {"id": 163111, "internal_url": "https://www.mobygames.com/user/163111/cavalary/", "name": "Cavalary"}, "type": {"id": 1, "name": "Numeric (Highest score is best)"}, "url": "http://xbox-mag.net/portal-2-__22872.html"}, {"citation": "What they say about sequels not holding up the original is often enough true, however it doesn\u2019t apply to Portal 2. Everything about Portal 2 is \u201cbigger and better\u201d than the original. You can clearly see that the developers made sure to keep the core of the gameplay from Portal intact, while enhancing every bit of the experience into a deeper, more fulfilling experience for Portal 2. With 2-player co-op and cross-platform gameplay thanks to Steam being brought over to the PS3 console, Valve is essentially \u201cchanging the game\u201d and we all thank them for it. Whether you pick up the Xbox 360, PC or PS3 version of the game, you will have a rich and rewarding experience seldom few bring to the table.", "date": "2011-06-20", "edit_object_url": "/approval/edit-object?type=47\u0026oid=45628356", "grade": null, "id": 214645, "internal_url": "https://www.mobygames.com/game/51233/portal-2/reviews/#critic-score-214645", "language": "en", "max_score": 10.0, "normalized_score": 90.0, "platform": {"id": 69, "name": "Xbox 360"}, "score": 9.0, "source": {"country": {"country_code": "us", "flag": "https://cdn.mobygames.com/9f436050-ab5e-11ed-b6d6-02420a000150.gif", "id": 1, "name": "United States"}, "description": null, "edit_object_url": "/approval/edit-object?type=46\u0026oid=49257723", "first_year": 2004, "id": 388, "internal_url": "https://www.mobygames.com/critic/388/gamingevolution/", "languages": [{"code": "en", "id": 36, "name": "English", "ordering": 360}], "last_year": null, "name": "GamingEvolution", "num_reviews": 138, "url": "http://www.gamingevolution.info/"}, "submitter": {"id": 170000, "internal_url": "https://www.mobygames.com/user/170000/mprunty/", "name": "Matthew Prunty"}, "type": {"id": 1, "name": "Numeric (Highest score is best)"}, "url": "http://gamingevolution.info/?id=12615"}, {"citation": "Allt detta r\u00e4cker l\u00e5ngt, f\u00f6rst\u00e5s. Och d\u00e5 har jag inte ens n\u00e4mnt co-op-l\u00e4get och utvecklarkommentarerna, som ger en i mitt tycke matig l\u00e4ngd till helheten. Fram med t\u00e5rtan allts\u00e5, Portal 2 \u00e5rets hittills b\u00e4sta spel.", "date": "2011-04-19", "edit_object_url": "/approval/edit-object?type=47\u0026oid=45616441", "grade": null, "id": 210105, "internal_url": "https://www.mobygames.com/game/51233/portal-2/reviews/#critic-score-210105", "language": "sv", "max_score": 10.0, "normalized_score": 90.0, "platform": {"id": 69, "name": "Xbox 360"}, "score": 9.0, "source": {"country": {"country_code": "se", "flag": "https://cdn.mobygames.com/9f3d1a06-ab5e-11ed-b6d6-02420a000150.gif", "id": 21, "name": "Sweden"}, "description": null, "edit_object_url": "/approval/edit-object?type=46\u0026oid=49257982", "first_year": 2001, "id": 626, "internal_url": "https://www.mobygames.com/critic/626/gamereactor-sweden/", "languages": [{"code": "sv", "id": 137, "name": "Swedish", "ordering": 1370}], "last_year": null, "name": "Gamereactor (Sweden)", "num_reviews": 1184, "url": "http://www.gamereactor.se/"}, "submitter": {"id": 55154, "internal_url": "https://www.mobygames.com/user/55154/disco-sounds-2088/", "name": "lights out party"}, "type": {"id": 1, "name": "Numeric (Highest score is best)"}, "url": "http://www.gamereactor.se/recensioner/26931/Portal+2/"}, {"citation": "Portal 2 er et spill som skiller seg fra mengden. Det gir en tilfredsstillende f\u00f8lelse \u00e5 l\u00f8se de intrikate g\u00e5tene, som takket v\u00e6re str\u00e5lende brettdesign holder seg utfordrende og interessante gjennom hele spillet. Valve leverer dialog og humor i s\u00e6rklasse, og for meg var det helt umulig \u00e5 ikke la seg bli sjarmert s\u00f8nder og sammen av robotenes personlighet. Sleng p\u00e5 en str\u00e5lende samarbeidsdel p\u00e5 toppen av det hele, og Portal 2 lever opp til forventningene. Hvem liker vel ikke roboter med f\u00f8lelser?", "date": "2011-04-19", "edit_object_url": "/approval/edit-object?type=47\u0026oid=45616436", "grade": null, "id": 210109, "internal_url": "https://www.mobygames.com/game/51233/portal-2/reviews/#critic-score-210109", "language": "no", "max_score": 10.0, "normalized_score": 90.0, "platform": {"id": 69, "name": "Xbox 360"}, "score": 9.0, "source": {"country": {"country_code": "no", "flag": "https://cdn.mobygames.com/d7733c3e-ab5e-11ed-b6d6-02420a000150.gif", "id": 34, "name": "Norway"}, "description": null, "edit_object_url": "/approval/edit-object?type=46\u0026oid=49257793", "first_year": 2000, "id": 1310, "internal_url": "https://www.mobygames.com/critic/1310/gamereactor-norway/", "languages": [{"code": "no", "id": 102, "name": "Norwegian", "ordering": 1020}], "last_year": null, "name": "Gamereactor (Norway)", "num_reviews": 168, "url": "http://www.gamereactor.no/"}, "submitter": {"id": 55154, "internal_url": "https://www.mobygames.com/user/55154/disco-sounds-2088/", "name": "lights out party"}, "type": {"id": 1, "name": "Numeric (Highest score is best)"}, "url": "http://www.gamereactor.no/anmeldelser/124260/Portal+2/"}, {"citation": "Overall, Portal 2 is an excellent game. Though it suffers from repetitive gameplay that may turn some gamers off, it\u2019s an accessible puzzle game in a genre that some people find hard to get into. Its elegant design and intelligent puzzles coupled with fantastic dialogue and visuals, make for a memorable gaming experience. Fans of the first game are sure to be impressed with this sequel, but newcomers will probably be impressed even more. It\u2019s the type of game that is so accessible that it\u2019ll make puzzle game cynics forget they\u2019re playing a game from a genre they\u2019ve never liked previously.", "date": "2011-04-22", "edit_object_url": "/approval/edit-object?type=47\u0026oid=45667553", "grade": null, "id": 218746, "internal_url": "https://www.mobygames.com/game/51233/portal-2/reviews/#critic-score-218746", "language": "en", "max_score": 5.0, "normalized_score": 90.0, "platform": {"id": 81, "name": "PlayStation 3"}, "score": 4.5, "source": {"country": {"country_code": "ca", "flag": "https://cdn.mobygames.com/9fa117cc-ab5e-11ed-b6d6-02420a000150.gif", "id": 5, "name": "Canada"}, "description": null, "edit_object_url": "/approval/edit-object?type=46\u0026oid=49254914", "first_year": 2010, "id": 1587, "internal_url": "https://www.mobygames.com/critic/1587/we-got-this-covered/", "languages": [{"code": "en", "id": 36, "name": "English", "ordering": 360}], "last_year": null, "name": "We Got This Covered", "num_reviews": 407, "url": "http://wegotthiscovered.com/"}, "submitter": {"id": 163111, "internal_url": "https://www.mobygames.com/user/163111/cavalary/", "name": "Cavalary"}, "type": {"id": 2, "name": "Star System"}, "url": "http://wegotthiscovered.com/video-game-review/portal-2-review-playstation-3-version/"}, {"citation": "Valves topchef Gabe Newell har sagt, at Portal 2 sandsynligvis er det bedste spil Valve nogensinde har lavet. Det er et udsagn der er sv\u00e6rt at bed\u00f8mme, fordi n\u00e6sten hvert eneste af udviklerens spil har v\u00e6ret skels\u00e6ttende. Af samme grund giver det heller ikke rigtig mening at kalde det for et af deres bedste spil. I stedet vil jeg sige dette: Portal 2 har overg\u00e5et mine temmelig h\u00f8je forventninger, og er den perfekte efterf\u00f8lger til det klassiske Portal. Det g\u00f8r alting rigtigt, og s\u00e6tter ikke en eneste fod forkert undervejs. Det er et spil alle burde pr\u00f8ve, og f\u00e5r min varmeste anbefaling.", "date": "2011-04-19", "edit_object_url": "/approval/edit-object?type=47\u0026oid=45616435", "grade": null, "id": 210106, "internal_url": "https://www.mobygames.com/game/51233/portal-2/reviews/#critic-score-210106", "language": "da", "max_score": 10.0, "normalized_score": 90.0, "platform": {"id": 69, "name": "Xbox 360"}, "score": 9.0, "source": {"country": {"country_code": "dk", "flag": "https://cdn.mobygames.com/c4d8fa64-ab5e-11ed-b6d6-02420a000150.gif", "id": 26, "name": "Denmark"}, "description": null, "edit_object_url": "/approval/edit-object?type=46\u0026oid=49257795", "first_year": 1998, "id": 845, "internal_url": "https://www.mobygames.com/critic/845/gamereactor-denmark/", "languages": [{"code": "da", "id": 33, "name": "Danish", "ordering": 330}], "last_year": null, "name": "Gamereactor (Denmark)", "num_reviews": 775, "url": "https://www.gamereactor.dk/"}, "submitter": {"id": 55154, "internal_url": "https://www.mobygames.com/user/55154/disco-sounds-2088/", "name": "lights out party"}, "type": {"id": 1, "name": "Numeric (Highest score is best)"}, "url": "http://www.gamereactor.dk/anmeldelser/83540/Portal+2/"}, {"citation": "For the sequel, Valve made the single player mode much longer and more in depth as well as added the co-op mode. As excellent as the story is and as well managed as co-op is, this game is very much worth the increased price tag compared to Portal. However, if you are still skeptical, Valve plans to produce and distribute downloadable content for Portal 2, including additional new test chambers and a challenge mode similar to its predecessor. They also announced that the PC version will have downloadable tools for making your own test chambers. You will only be able to make the tests on Windows systems, but all platforms available for the game will have access to the user-made levels. PS3 will be provided the content via Steamworks.", "date": "2011-05-19", "edit_object_url": "/approval/edit-object?type=47\u0026oid=4299187140", "grade": null, "id": 657396, "internal_url": "https://www.mobygames.com/game/51233/portal-2/reviews/#critic-score-657396", "language": "en", "max_score": 5.0, "normalized_score": 90.0, "platform": {"id": 3, "name": "Windows"}, "score": 4.5, "source": {"country": {"country_code": "us", "flag": "https://cdn.mobygames.com/9f436050-ab5e-11ed-b6d6-02420a000150.gif", "id": 1, "name": "United States"}, "description": null, "edit_object_url": "/approval/edit-object?type=46\u0026oid=4296017475", "first_year": 2010, "id": 3548, "internal_url": "https://www.mobygames.com/critic/3548/smashpad/", "languages": [{"code": "en", "id": 36, "name": "English", "ordering": 360}], "last_year": null, "name": "SmashPad", "num_reviews": 123, "url": "https://smashpad.com/"}, "submitter": {"id": 1121630, "internal_url": "https://www.mobygames.com/user/1121630/rocket55/", "name": "Rocket"}, "type": {"id": 2, "name": "Star System"}, "url": "https://smashpad.com/portal-2-review/"}, {"citation": "Portal 2 ist im Vergleich zu Portal 1 das, was normalerweise herauskommt, wenn ein Indie-Spiel zum Triple-A-Titel aufgeblasen wird, im Positiven wie im (schwach) Negativen: Klar, der Wow-Effekt des Vorg\u00e4ngers kann f\u00fcr dessen Kenner nicht wiederholt werden, und GlaDOS ist auch eine alte Bekannte statt eine neue Erfahrung. Doch Valve hat sich eine Vielzahl neuer, gut passender Elemente ausgedacht, die das immer gleiche Grundprinzip kunstvoll variieren.", "date": "2011-04-19", "edit_object_url": "/approval/edit-object?type=47\u0026oid=4299186841", "grade": null, "id": 657390, "internal_url": "https://www.mobygames.com/game/51233/portal-2/reviews/#critic-score-657390", "language": "de", "max_score": 10.0, "normalized_score": 90.0, "platform": {"id": 3, "name": "Windows"}, "score": 9.0, "source": {"country": {"country_code": "de", "flag": "https://cdn.mobygames.com/9f8eb00a-ab5e-11ed-b6d6-02420a000150.gif", "id": 9, "name": "Germany"}, "description": null, "edit_object_url": "/approval/edit-object?type=46\u0026oid=49258099", "first_year": 2008, "id": 1118, "internal_url": "https://www.mobygames.com/critic/1118/gamersglobal/", "languages": [{"code": "de", "id": 47, "name": "German", "ordering": 470}], "last_year": null, "name": "GamersGlobal", "num_reviews": 225, "url": "http://www.gamersglobal.de/"}, "submitter": {"id": 1121630, "internal_url": "https://www.mobygames.com/user/1121630/rocket55/", "name": "Rocket"}, "type": {"id": 1, "name": "Numeric (Highest score is best)"}, "url": "https://www.gamersglobal.de/test/portal-2?page=0,4"}, {"citation": "What seemed like a silly one-off intended to lead in to the next Half-Life (whenever that is coming) has turned into a premiere franchise that can stand on its own two legs. Portal 2 is everything a good sequel should be. It continues the story without repeating it, and adds new modes and features without mucking up what worked about the first game. And, most importantly, it still feels fresh. Too often we play sequels simply out of habit, because we liked earlier installments. There\u0027s no such sense of weariness about Portal 2, which can proudly stand up to any game, sequel or not. And then drop those other games through a hole in the floor.", "date": "2011-05-14", "edit_object_url": "/approval/edit-object?type=47\u0026oid=45667597", "grade": null, "id": 218748, "internal_url": "https://www.mobygames.com/game/51233/portal-2/reviews/#critic-score-218748", "language": "en", "max_score": 5.0, "normalized_score": 90.0, "platform": {"id": 81, "name": "PlayStation 3"}, "score": 4.5, "source": {"country": {"country_code": "us", "flag": "https://cdn.mobygames.com/9f436050-ab5e-11ed-b6d6-02420a000150.gif", "id": 1, "name": "United States"}, "description": null, "edit_object_url": "/approval/edit-object?type=46\u0026oid=49259416", "first_year": 2002, "id": 461, "internal_url": "https://www.mobygames.com/critic/461/video-game-talk/", "languages": [{"code": "en", "id": 36, "name": "English", "ordering": 360}], "last_year": null, "name": "Video Game Talk", "num_reviews": 624, "url": "http://www.videogametalk.com/"}, "submitter": {"id": 163111, "internal_url": "https://www.mobygames.com/user/163111/cavalary/", "name": "Cavalary"}, "type": {"id": 2, "name": "Star System"}, "url": "http://www.videogametalk.com/reviews/1235/portal-2/"}, {"citation": "Portal 2 is pure genius. With gameplay growing ever more addictive and new characters always threatening to steal the spotlight, Portal 2 is one of the best games of 2011. A perfect and true sequel to the 2007 hit, Portal 2 provides everything that a fantastically designed sequel needs. The graphics and style are noticeably better, the writing is top-notch, the gameplay is as enthralling as before, the developer commentary keep players entertained, and the rest is tied nicely together with beloved characters. With \u201cstill alive\u201d quotes and cake references kept to a minimum, Portal 2 steps the franchise out from the small tech demo with a neat story and into a work Valve can proudly place next to its Half-Life franchise.", "date": "2011-04-19", "edit_object_url": "/approval/edit-object?type=47\u0026oid=45667598", "grade": null, "id": 218752, "internal_url": "https://www.mobygames.com/game/51233/portal-2/reviews/#critic-score-218752", "language": "en", "max_score": 10.0, "normalized_score": 90.0, "platform": {"id": 81, "name": "PlayStation 3"}, "score": 9.0, "source": {"country": {"country_code": "us", "flag": "https://cdn.mobygames.com/9f436050-ab5e-11ed-b6d6-02420a000150.gif", "id": 1, "name": "United States"}, "description": null, "edit_object_url": "/approval/edit-object?type=46\u0026oid=49259491", "first_year": 1991, "id": 5, "internal_url": "https://www.mobygames.com/critic/5/gamezone/", "languages": [{"code": "en", "id": 36, "name": "English", "ordering": 360}], "last_year": 2021, "name": "GameZone", "num_reviews": 4569, "url": "http://www.gamezone.com/"}, "submitter": {"id": 163111, "internal_url": "https://www.mobygames.com/user/163111/cavalary/", "name": "Cavalary"}, "type": {"id": 1, "name": "Numeric (Highest score is best)"}, "url": "http://ps3.gamezone.com/reviews/item/portal_2"}, {"citation": "Let\u2019s wrap this bad boy up. The writing is comical and entertaining. The gameplay is fun with just the right amount of challenge and difficulty. The pacing of the game is great. The graphical presentation has improved. The co-op mode is extremely fun and engaging. Not to mention, the voice acting is positively brilliant. Load times are on the long side and are probably much more noticeable on consoles, the story isn\u0027t all that much different from the first game, but as mentioned earlier, the writing and characterizations more than make up for it. Portal 2 is an experience you won\u0027t soon forget.", "date": "2011-04-20", "edit_object_url": "/approval/edit-object?type=47\u0026oid=4299174633", "grade": null, "id": 657224, "internal_url": "https://www.mobygames.com/game/51233/portal-2/reviews/#critic-score-657224", "language": "en", "max_score": 10.0, "normalized_score": 90.0, "platform": {"id": 3, "name": "Windows"}, "score": 9.0, "source": {"country": {"country_code": "us", "flag": "https://cdn.mobygames.com/9f436050-ab5e-11ed-b6d6-02420a000150.gif", "id": 1, "name": "United States"}, "description": null, "edit_object_url": "/approval/edit-object?type=46\u0026oid=49254936", "first_year": 2009, "id": 1479, "internal_url": "https://www.mobygames.com/critic/1479/gamingunionnet/", "languages": [{"code": "en", "id": 36, "name": "English", "ordering": 360}], "last_year": null, "name": "GamingUnion.net", "num_reviews": 61, "url": "http://www.gamingunion.net/"}, "submitter": {"id": 1121630, "internal_url": "https://www.mobygames.com/user/1121630/rocket55/", "name": "Rocket"}, "type": {"id": 1, "name": "Numeric (Highest score is best)"}, "url": "https://web.archive.org/web/20110426061413/http://www.gamingunion.net/reviews/portal-2--482.html?page=2"}, {"citation": "We completed the single player game in a day (with several breaks for comfort and the necessities of life), for an estimated total of 7-8 hours\u2019 worth of brain bending entertainment. There are a few more hours to be had in the two player co-op game, and Portal 2 offers more gaming hours than the original. Ultimately, however, you have to weigh up the cost against the replay value \u2013 which is low, unless you\u2019re into collecting trophies or DLC. For us, this was the only downside to an excellent overall package, and a truly worthy sequel to one of the most engrossing and popular puzzlers around.", "date": "2011-04-29", "edit_object_url": "/approval/edit-object?type=47\u0026oid=45667617", "grade": null, "id": 218749, "internal_url": "https://www.mobygames.com/game/51233/portal-2/reviews/#critic-score-218749", "language": "en", "max_score": 10.0, "normalized_score": 90.0, "platform": {"id": 81, "name": "PlayStation 3"}, "score": 9.0, "source": {"country": {"country_code": "us", "flag": "https://cdn.mobygames.com/9f436050-ab5e-11ed-b6d6-02420a000150.gif", "id": 1, "name": "United States"}, "description": null, "edit_object_url": "/approval/edit-object?type=46\u0026oid=49259576", "first_year": 2004, "id": 607, "internal_url": "https://www.mobygames.com/critic/607/nzgamer/", "languages": [{"code": "en", "id": 36, "name": "English", "ordering": 360}], "last_year": null, "name": "NZGamer", "num_reviews": 635, "url": "http://nzgamer.com/index.php"}, "submitter": {"id": 163111, "internal_url": "https://www.mobygames.com/user/163111/cavalary/", "name": "Cavalary"}, "type": {"id": 1, "name": "Numeric (Highest score is best)"}, "url": "http://nzgamer.com/ps3/reviews/1342/portal-2.html"}, {"citation": "Portal 2\u2032s clearly aimed at fans of the original, and rightly so \u2013 Valve have made no concessions to the uninitiated beyond the first hour or so: the puzzles might be a tad easier, but there\u2019s much more of them (the game takes between 10 and 12 hours to get through) and there\u2019s huge sections well outside the white walls of the labs that take real concentration. The biggest disappointment is realising that, once you\u2019re done, Valve Time will mean we\u2019ll be without the warm bosom of GLaDOS for \u2013 presumably \u2013 years.  Regardless, games like this don\u2019t come around very often, and if you miss out on this one you\u2019ll be skipping one of the finest examples of the medium the industry has to offer: Portal 2 is compelling, exciting, wildly capricious and, most importantly, laugh out loud funny.", "date": "2011-04-19", "edit_object_url": "/approval/edit-object?type=47\u0026oid=45667638", "grade": null, "id": 218754, "internal_url": "https://www.mobygames.com/game/51233/portal-2/reviews/#critic-score-218754", "language": "en", "max_score": 10.0, "normalized_score": 90.0, "platform": {"id": 81, "name": "PlayStation 3"}, "score": 9.0, "source": {"country": {"country_code": "uk", "flag": "https://cdn.mobygames.com/9f7e9f08-ab5e-11ed-b6d6-02420a000150.gif", "id": 22, "name": "United Kingdom"}, "description": null, "edit_object_url": "/approval/edit-object?type=46\u0026oid=49257856", "first_year": 2007, "id": 1148, "internal_url": "https://www.mobygames.com/critic/1148/thesixthaxis/", "languages": [{"code": "en", "id": 36, "name": "English", "ordering": 360}], "last_year": null, "name": "TheSixthAxis", "num_reviews": 1283, "url": "http://www.thesixthaxis.com/"}, "submitter": {"id": 163111, "internal_url": "https://www.mobygames.com/user/163111/cavalary/", "name": "Cavalary"}, "type": {"id": 1, "name": "Numeric (Highest score is best)"}, "url": "http://www.thesixthaxis.com/2011/04/19/review-portal-2/"}, {"citation": "Druga cz\u0119\u015b\u0107 Portal podoba\u0142a mi si\u0119 bardzo, dzi\u0119ki wprowadzonym przez tw\u00f3rc\u00f3w nowo\u015bciom, tytu\u0142 sta\u0142 si\u0119 jeszcze bardziej atrakcyjny wzgl\u0119dem poprzednika. W mojej ocenie \u201edw\u00f3jka\u201d okaza\u0142a si\u0119 jeszcze lepsz\u0105 gr\u0105 ni\u017c pierwsza. Ostatnimi czasy s\u0142yszymy, \u017ce Valve powr\u00f3ci\u0142o do tworzenia gier. Przyznam szczerze, \u017ce po cichu licz\u0119, \u017ce pog\u0142oski na temat powstania trzeciej cz\u0119\u015bci gry oka\u017c\u0105 si\u0119 prawdziwe, bo Portal 2 a\u017c prosi si\u0119 o stworzenie jeszcze jednej, ostatniej gry z Chell w roli g\u0142\u00f3wnej.", "date": "2019-04-10", "edit_object_url": "/approval/edit-object?type=47\u0026oid=3030005223", "grade": null, "id": 389019, "internal_url": "https://www.mobygames.com/game/51233/portal-2/reviews/#critic-score-389019", "language": "pl", "max_score": 100.