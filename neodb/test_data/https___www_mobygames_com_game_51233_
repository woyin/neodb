obygames.com/user/136314/patrick_b/", "name": "Patrick Bregger"}, "type": {"id": 1, "name": "Numeric (Highest score is best)"}, "url": "http://www.4players.de/4players.php/dispbericht/Allgemein/Test/21603/71752/0/Portal_2.html"}, {"citation": "Het originele Portal was een geweldige game en Valve zet met Portal 2 een geweldig vervolg neer. Het verhaal is groter, de personages diepgaander en de gameplay is verder uitgebreid. De game barst van de cynische humor en goed geschreven dialogen. De wereld van Portal 2 is een meeslepende achtbaan, die alleen halverwege even wordt afgeremd. Naast de singleplayer kun je nog veel meer uitdaging verwachten in de co-op-campagne, waar echt het uiterste van je wordt gevraagd.", "date": "2011-04-23", "edit_object_url": "/approval/edit-object?type=47\u0026oid=45737964", "grade": null, "id": 218722, "internal_url": "https://www.mobygames.com/game/51233/portal-2/reviews/#critic-score-218722", "language": "nl", "max_score": 100.0, "normalized_score": 92.0, "platform": {"id": 69, "name": "Xbox 360"}, "score": 92.0, "source": {"country": {"country_code": "nl", "flag": "https://cdn.mobygames.com/c4f2d308-ab5e-11ed-b6d6-02420a000150.gif", "id": 16, "name": "The Netherlands"}, "description": null, "edit_object_url": "/approval/edit-object?type=46\u0026oid=49257873", "first_year": 2000, "id": 1019, "internal_url": "https://www.mobygames.com/critic/1019/gamez/", "languages": [{"code": "nl", "id": 34, "name": "Dutch", "ordering": 340}], "last_year": null, "name": "GameZ", "num_reviews": 42, "url": "http://www.gamez.nl/"}, "submitter": {"id": 163111, "internal_url": "https://www.mobygames.com/user/163111/cavalary/", "name": "Cavalary"}, "type": {"id": 1, "name": "Numeric (Highest score is best)"}, "url": "http://www.gamez.nl/puzzle/3673-portal-2/review/33879-portal-2.html"}, {"citation": "Portal besitzt auch in der Fortsetzung den Charme eines Independent-Titels, schafft es aber gleichzeitig, mit einem erheblich gr\u00f6\u00dferen Umfang zu \u00f