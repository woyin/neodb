  <script>
    // Position "hide ad" wrappers dynamically based on actual ad height
    function positionAdWrappers() {
      document.querySelectorAll('.ad-hide-wrapper').forEach((wrapper) => {
        const parent = wrapper.parentElement;
        if (!parent) return;

        // Could be a Monumetric ad (id starts with 'mmt-') or a fake ad
        const adElement = parent.querySelector('[id^="mmt-"], .fake-ad');

        if (!adElement) return;

        const updatePosition = () => {
          const adHeight = adElement.offsetHeight;
          if (adHeight > 0) {
            wrapper.style.top = `${adHeight}px`;
            parent.style.height = `calc(${adHeight}px + 1lh)`;
          }
        };

        // For fake ads, position immediately
        if (adElement.classList.contains('fake-ad')) {
          updatePosition();
          return;
        }

        // For real ads, wait for content to load
        const observer = new MutationObserver((mutations, obs) => {
          updatePosition();
          // Check if ad has loaded (has height and children)
          if (adElement.offsetHeight > 0 && adElement.children.length > 0) {
            obs.disconnect();
          }
        });

        observer.observe(adElement, {
          childList: true,
          subtree: true,
        });

        // Also update on initial load in case ad is already there
        updatePosition();

        // Fallback: update position after a delay in case MutationObserver doesn't catch it
        setTimeout(updatePosition, 1000);
        setTimeout(updatePosition, 2000);
      });
    }

    // Run on page load
    document.addEventListener('DOMContentLoaded', positionAdWrappers);

    // Re-run after HTMX updates in case new ads are loaded
    document.body.addEventListener('htmx:afterSwap', positionAdWrappers);
  </script>
